# ─── Database (PostgreSQL Connection) ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=fashion_jewellery_db

# ─── Server Configuration ─────────────────────────────────
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# ─── Authentication Configuration ─────────────────────────
JWT_SECRET=your_jwt_signing_secret_key
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# ─── Static Administrative Credentials ─────────────────────
# These environment variables configure the direct master admin user
ADMIN_EMAIL=admin@jewellery.com
ADMIN_PASSWORD_HASH=$2b$12$ArJwVJYWmQsFUOYHzgqdmOyanWoyDy5.hj.fvg34SEzwC44F8nQnS
ADMIN_NAME=System Admin
